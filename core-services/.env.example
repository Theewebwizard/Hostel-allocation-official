# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=hostel_allocation

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# Application
PORT=3000
NODE_ENV=development

# Allocation Engine
ALLOCATION_ENGINE_URL=http://localhost:8000

# Webhook Security (must match WEBHOOK_SECRET in allocation-engine/.env)
WEBHOOK_SECRET=change-this-secret-in-production

# Public base URL of this NestJS service, used to build callback_url sent to Python
# Local (bare-metal): http://localhost:3000
# Docker Compose:     http://core-services:3000
CORE_SERVICES_BASE_URL=http://localhost:3000
