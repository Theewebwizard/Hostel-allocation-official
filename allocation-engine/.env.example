# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=hostel_allocation

# Core Services API
CORE_SERVICES_URL=http://localhost:3000

# Webhook Security (must match WEBHOOK_SECRET in core-services/.env)
WEBHOOK_SECRET=change-this-secret-in-production

# Allocation Engine
ALLOCATION_PORT=8000

# Redis — ephemeral run-state store (set REDIS_URL when running with Docker or a remote Redis)
REDIS_URL=redis://localhost:6379/0
